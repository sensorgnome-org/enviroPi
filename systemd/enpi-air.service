[Unit]
Description=ENPi - air quality monitoring on the rpi
After=network.target

[Service]
Type=simple
User=ampi
Group=ampi
WorkingDirectory=/opt/enpi
#ExecStart=/bin/bash -c '/opt/enpi/update.sh && /opt/enpi/env/bin/python /opt/enpi/enpi-air.py'
ExecStart=/opt/enpi/env/bin/python /opt/enpi/enpi-air.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target